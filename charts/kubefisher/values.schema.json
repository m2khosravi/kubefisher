{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "kubefisher chart values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string", "minLength": 1 } }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 0, "maximum": 1 },
    "podLabels": { "type": "object" },
    "podAnnotations": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "config": {
      "type": "object",
      "required": ["prometheusUrl", "reconcileInterval", "pricingRefreshInterval", "httpAddr", "logFormat"],
      "properties": {
        "prometheusUrl": { "type": "string", "minLength": 1, "format": "uri" },
        "reconcileInterval": { "type": "string", "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$" },
        "pricingRefreshInterval": { "type": "string", "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$" },
        "httpAddr": { "type": "string", "pattern": "^:[0-9]+$|^[^:]+:[0-9]+$" },
        "logFormat": { "type": "string", "enum": ["json", "text"] }
      }
    },
    "gpuPricing": {
      "type": "object",
      "required": ["create", "name", "dataKey"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "dataKey": { "type": "string", "minLength": 1 },
        "pricing": { "type": "object" }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "additionalLabels": { "type": "object" }
          }
        },
        "prometheusRule": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "additionalLabels": { "type": "object" }
          }
        },
        "costPatcher": {
          "type": "object",
          "properties": {
            "tokenRateWindow": {
              "type": "string",
              "minLength": 1,
              "description": "Prometheus rate window for the cost_per_token denominator (e.g. '5m')."
            }
          }
        },
        "grafanaDashboard": {
          "type": "object",
          "required": ["enabled", "sidecarLabel", "sidecarLabelValue"],
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "sidecarLabel": { "type": "string", "minLength": 1 },
            "sidecarLabelValue": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "operator": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "replicaCount": { "type": "integer", "minimum": 0, "maximum": 3 },
        "prometheusUrl": { "type": "string" },
        "resources": { "type": "object" },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "podLabels": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "webhook": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "certManager": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "issuerName": { "type": "string" },
                "certificateName": { "type": "string" },
                "secretName": { "type": "string" }
              }
            },
            "namespaceSelector": {
              "type": "object",
              "properties": {
                "labelKey": { "type": "string", "minLength": 1 },
                "labelValue": { "type": "string", "minLength": 1 },
                "excludedNamespaces": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  }
}
